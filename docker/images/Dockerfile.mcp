# Lightweight MCP image for this fork (and compatible upstream bundles).
# Uses official Node slim instead of full Ubuntu + hand-installed Node.
FROM node:22-bookworm-slim

LABEL maintainer="Penpot <docker@penpot.app>"

ENV LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    DEBIAN_FRONTEND=noninteractive \
    PENPOT_MCP_SERVER_HOST=0.0.0.0 \
    NODE_ENV=production

RUN set -ex; \
    groupadd -g 1001 penpot; \
    useradd -U -M -u 1001 -g 1001 -s /bin/false -d /opt/penpot penpot; \
    apt-get -qq update; \
    apt-get -qqy --no-install-recommends install \
      ca-certificates \
      curl \
      tini \
    ; \
    rm -rf /var/lib/apt/lists/*; \
    corepack enable; \
    mkdir -p /opt/penpot; \
    chown -R penpot:penpot /opt/penpot

ARG BUNDLE_PATH="./bundle-mcp/"
COPY --chown=penpot:penpot $BUNDLE_PATH /opt/penpot/mcp/

WORKDIR /opt/penpot/mcp
USER penpot:penpot

# Bundle ships a small ./setup that runs `pnpm install -P` for production deps.
RUN chmod +x ./setup && ./setup

# tini reaps zombies if native deps spawn children (e.g. sharp).
ENTRYPOINT ["tini", "--"]
CMD ["node", "index.js", "--multi-user"]
