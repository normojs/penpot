# Copy to .env.fork and edit (do not commit real secrets).
# Used with: docker compose --env-file .env.fork -f docker-compose.yaml -f docker-compose.fork.yaml up -d

FORK_IMAGE_TAG=dev

# Generate for production:
# python3 -c "import secrets; print(secrets.token_urlsafe(64))"
PENPOT_SECRET_KEY=change-this-insecure-key

# First-deploy login (create-once; does not update password on restart)
PENPOT_DEFAULT_ADMIN_EMAIL=admin@example.com
PENPOT_DEFAULT_ADMIN_PASSWORD=changeme123
PENPOT_DEFAULT_ADMIN_FULLNAME=Administrator
