{
  "name": "mcp-plugin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "vite build --watch --config vite.config.ts",
    "start:multi-user": "pnpm run start",
    "build": "tsc && vite build --config vite.release.config.ts && node ../../scripts/package-plugin-assets.mjs metadata",
    "package:frontend": "pnpm run build && node ../../scripts/package-plugin-assets.mjs package",
    "check:frontend": "node ../../scripts/package-plugin-assets.mjs check",
    "types:check": "tsc --noEmit",
    "clean": "rm -rf dist/"
  },
  "dependencies": {
    "@penpot/plugin-styles": "1.4.1",
    "@penpot/plugin-types": "1.4.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.8",
    "vite-live-preview": "^0.3.2"
  }
}
